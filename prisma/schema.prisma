datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
  dealers  Dealer[]  @relation("BrandToDealer")
}

model Dealer {
  id       String    @id @default(cuid())
  name     String
  location String?
  email    String    @unique
  xmlUrl   String?
  products Product[]
  brands   Brand[]   @relation("BrandToDealer")
}

model Product {
  id         String   @id
  partNumber String
  name       String
  price      Float
  stock      Int
  brandId    String
  brand      Brand    @relation(fields: [brandId], references: [id])
  dealerId   String
  dealer     Dealer   @relation(fields: [dealerId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
}