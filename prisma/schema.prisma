datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

model MasterProduct {
  id           String          @id @default(cuid())
  partNumber   String          @unique
  name         String
  brand        String
  officialMsrp Float
  updatedAt    DateTime        @updatedAt
  stocks       SupplierStock[]
  cartItems    CartItem[]
}

model CartItem {
  id              String        @id @default(cuid())
  userId          String        // Clerk user id
  masterProductId String
  supplierStockId String?       // best-price supplier stock at add time
  partNumber      String        // at time of add, for display
  quantity        Int
  price           Float         // price at time of add (best supplier or MSRP)
  brand           String
  description     String        // product name at time of add
  createdAt       DateTime      @default(now())

  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)
  supplierStock   SupplierStock? @relation(fields: [supplierStockId], references: [id], onDelete: SetNull)

  @@unique([userId, masterProductId])
  @@index([userId])
}

model Order {
  id                 String      @id @default(cuid())
  userId             String      // Clerk user id
  status             String      @default("PENDING") // PENDING, CONFIRMED, PROCESSING, SHIPPED, READY_FOR_PICKUP, COMPLETED, CANCELLED
  totalPrice         Float       // total with VAT at time of order
  shippingName       String?
  shippingAddress    String?
  shippingCity       String?
  shippingPostalCode String?
  shippingPhone      String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  items     OrderItem[]
  subOrders SubOrder[]

  @@index([userId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  masterProductId String
  partNumber      String
  description     String
  price           Float    // unit price at time of order
  quantity        Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

// Vendor order: one per supplier for a given master order
model SubOrder {
  id         String   @id @default(cuid())
  orderId    String
  supplierId String
  status     String   @default("PENDING")
  totalPrice Float    // sum of (price * quantity) for this supplier
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order    Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplier Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  items    SubOrderItem[]

  @@index([orderId])
  @@index([supplierId])
}

model SubOrderItem {
  id              String   @id @default(cuid())
  subOrderId      String
  masterProductId String
  partNumber      String
  description     String
  price           Float
  quantity        Int

  subOrder SubOrder @relation(fields: [subOrderId], references: [id], onDelete: Cascade)

  @@index([subOrderId])
}

model Supplier {
  id       String          @id @default(cuid())
  name     String          @unique
  location String
  email    String?         // for order notifications
  userId   String?         @unique // Clerk user id – links supplier portal user to this record
  stocks   SupplierStock[]
  subOrders SubOrder[]
}

model SupplierStock {
  id              String         @id @default(cuid())
  masterProductId String
  supplierId      String
  supplierPrice   Float
  quantity        Int
  updatedAt       DateTime       @updatedAt

  masterProduct   MasterProduct  @relation(fields: [masterProductId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])
  cartItems       CartItem[]

  @@unique([masterProductId, supplierId])
}

model Category {
  id    String  @id @default(cuid())
  name  String  @unique
  brands Brand[]

  @@map("categories")
}

model Brand {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  logoUrl    String?  // optional image URL for brand logo
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  updateLogs UpdateLog[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@map("brands")
}

model UpdateLog {
  id           String    @id @default(cuid())
  userId       String
  userName     String
  categoryId   String?
  categoryName String?   // Audit: category name at time of update
  brandId      String?
  brandName    String?   // Audit: brand name at time of update
  createdAt    DateTime  @default(now())

  brand Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([brandId])
}

// Subscription tier per user (Clerk userId). Source of truth for FREE | BASIC | PRO.
model Profile {
  id               String   @id @default(cuid())
  userId           String   @unique // Clerk user id
  subscriptionTier String   @default("FREE") // FREE | BASIC | PRO
  updatedAt        DateTime @updatedAt
}

// Universal Importer: saved field mappings + options for reuse
model ImportProfile {
  id          String   @id @default(cuid())
  name        String   @unique
  targetTable String   // MASTER_CATALOG | SUPPLIER_STOCK
  fileType    String   // CSV | XML | XLSX
  mapping     Json     // which file column maps to which DB field
  config      Json     // price multipliers, category defaults, etc.
  lastUsed    DateTime
}