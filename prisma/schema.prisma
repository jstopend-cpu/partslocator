datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

model MasterProduct {
  id           String          @id @default(cuid())
  partNumber   String          @unique
  name         String
  brand        String
  officialMsrp Float
  updatedAt    DateTime        @updatedAt
  stocks       SupplierStock[]
  cartItems    CartItem[]
}

model CartItem {
  id              String        @id @default(cuid())
  userId          String        // Clerk user id
  masterProductId String
  partNumber      String        // at time of add, for display
  quantity        Int
  price           Float         // price at time of add (e.g. officialMsrp)
  brand           String
  description     String        // product name at time of add
  createdAt       DateTime      @default(now())

  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  @@unique([userId, masterProductId])
  @@index([userId])
}

model Order {
  id         String      @id @default(cuid())
  userId     String      // Clerk user id
  status     String      @default("PENDING") // e.g. PENDING, CONFIRMED, SHIPPED
  totalPrice Float       // total with VAT at time of order
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  masterProductId String
  partNumber      String
  description     String
  price           Float    // unit price at time of order
  quantity        Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Supplier {
  id       String          @id @default(cuid())
  name     String          @unique
  location String
  stocks   SupplierStock[]
}

model SupplierStock {
  id              String         @id @default(cuid())
  masterProductId String
  supplierId      String
  supplierPrice   Float
  quantity        Int
  updatedAt       DateTime       @updatedAt

  masterProduct   MasterProduct  @relation(fields: [masterProductId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])

  @@unique([masterProductId, supplierId])
}

model UpdateLog {
  id        String   @id @default(cuid())
  userId    String   // Clerk user id
  userName  String   // Display name at time of update
  brand     String
  createdAt DateTime @default(now())

  @@index([createdAt])
}