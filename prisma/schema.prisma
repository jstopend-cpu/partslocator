datasource db {
provider = "postgresql"
}

generator client {
provider   = "prisma-client-js"
engineType = "library"
}

model Brand {
id       String    @id @default(cuid())
name     String    @unique
products Product[]
dealers  Dealer[]  @relation("BrandToDealer")
}

model Dealer {
id       String    @id @default(cuid())
name     String
location String?
email    String    @unique
xmlUrl   String?
products Product[]
brands   Brand[]   @relation("BrandToDealer")
}

model Product {
id          String   @id
partNumber  String
name        String
price       Float
stock       Int      @default(0)
lastUpdate  DateTime @default(now()) @updatedAt
brandId     String
brand       Brand    @relation(fields: [brandId], references: [id])
dealerId    String
dealer      Dealer   @relation(fields: [dealerId], references: [id])
@@index([partNumber])
}