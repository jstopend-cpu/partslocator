// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id        String   @id @default(cuid())
  name      String
  ean       String   @unique
  supplier  String
  price     Float
  stock     Int
  updatedAt DateTime @updatedAt
}