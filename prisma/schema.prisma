datasource db {
  provider = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  engineType      = "library"
}

model MasterProduct {
  id           String          @id @default(cuid())
  partNumber   String          @unique
  name         String
  brand        String
  officialMsrp Float
  updatedAt    DateTime        @updatedAt
  stocks       SupplierStock[]
  cartItems    CartItem[]
}

model CartItem {
  id              String        @id @default(cuid())
  userId          String        // Clerk user id
  masterProductId String
  partNumber      String        // at time of add, for display
  quantity        Int
  price           Float         // price at time of add (e.g. officialMsrp)
  brand           String
  description     String        // product name at time of add
  createdAt       DateTime      @default(now())

  masterProduct   MasterProduct @relation(fields: [masterProductId], references: [id], onDelete: Cascade)

  @@unique([userId, masterProductId])
  @@index([userId])
}

model Supplier {
  id       String          @id @default(cuid())
  name     String          @unique
  location String
  stocks   SupplierStock[]
}

model SupplierStock {
  id              String         @id @default(cuid())
  masterProductId String
  supplierId      String
  supplierPrice   Float
  quantity        Int
  updatedAt       DateTime       @updatedAt

  masterProduct   MasterProduct  @relation(fields: [masterProductId], references: [id])
  supplier        Supplier       @relation(fields: [supplierId], references: [id])

  @@unique([masterProductId, supplierId])
}